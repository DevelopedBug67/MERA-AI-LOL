rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is accessing their own data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for the 'videos' collection
    match /videos/{videoId} {
      // Users can read their own generated videos
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      
      // Users cannot create/update directly from the client.
      // Creation and updates are handled securely by Cloud Functions.
      allow create, update, delete: if false; 
    }
  }
}
